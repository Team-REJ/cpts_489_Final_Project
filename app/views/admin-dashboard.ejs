<!DOCTYPE html>
<html lang="en">
<head><%- include('partials/head') %></head>
<body>
<%- include('partials/navbar') %>

<!-- Page header -->
<div class="page-header">
  <div class="container-fluid">
    <div class="d-flex justify-content-between align-items-start">
      <div>
        <h1 class="h3 fw-bold mb-0"><i class="bi bi-shield-lock-fill me-2"></i>Admin Dashboard</h1>
        <p class="text-muted small mb-0">Moderate listings, manage users, and monitor platform health.</p>
      </div>
      <span class="badge bg-warning text-dark px-3 py-2"><i class="bi bi-shield-fill me-1"></i>ADMIN</span>
    </div>
  </div>
</div>

<div class="container-fluid py-0">
  <div class="row g-0" style="min-height:calc(100vh - 56px);">

    <!-- Sidebar -->
    <div class="col-lg-2 bg-white border-end py-4">
      <div class="px-3 mb-3">
        <div class="small text-uppercase text-muted fw-bold mb-2">Navigation</div>
      </div>
      <nav class="nav flex-column">
        <a class="nav-link active d-flex align-items-center" href="/admin"
           style="background:var(--crimson-bg);color:var(--crimson);padding:0.55rem 1.25rem;font-weight:600;font-size:0.9rem;">
          <i class="bi bi-speedometer2 me-2"></i>Overview
        </a>
        <a class="nav-link d-flex align-items-center" href="/admin/users"
           style="padding:0.55rem 1.25rem;color:#374151;font-size:0.9rem;">
          <i class="bi bi-people me-2"></i>Users
        </a>
        <a class="nav-link d-flex align-items-center" href="/listings"
           style="padding:0.55rem 1.25rem;color:#374151;font-size:0.9rem;">
          <i class="bi bi-grid me-2"></i>All Listings
        </a>
        <hr class="mx-3 my-2" />
        <a class="nav-link d-flex align-items-center" href="/"
           style="padding:0.55rem 1.25rem;color:#374151;font-size:0.9rem;">
          <i class="bi bi-arrow-left me-2"></i>Back to Site
        </a>
      </nav>
    </div>

    <!-- Main Content -->
    <div class="col-lg-10 p-4" style="background:#f9fafb;">

      <%- include('partials/alerts') %>

      <!-- Stats -->
      <div class="row g-3 mb-4">
        <div class="col-6 col-lg-3">
          <div class="stat-card">
            <div class="d-flex justify-content-between">
              <div>
                <div class="stat-number text-crimson"><%= summary.total_users %></div>
                <div class="stat-label">Total Users</div>
              </div>
              <i class="bi bi-people stat-icon"></i>
            </div>
          </div>
        </div>
        <div class="col-6 col-lg-3">
          <div class="stat-card">
            <div class="d-flex justify-content-between">
              <div>
                <div class="stat-number" style="color:#16a34a;"><%= summary.active_listings %></div>
                <div class="stat-label">Active Listings</div>
              </div>
              <i class="bi bi-check-circle stat-icon"></i>
            </div>
          </div>
        </div>
        <div class="col-6 col-lg-3">
          <div class="stat-card">
            <div class="d-flex justify-content-between">
              <div>
                <div class="stat-number text-warning"><%= pendingCount %></div>
                <div class="stat-label">Pending Approval</div>
              </div>
              <i class="bi bi-hourglass-split stat-icon"></i>
            </div>
          </div>
        </div>
        <div class="col-6 col-lg-3">
          <div class="stat-card">
            <div class="d-flex justify-content-between">
              <div>
                <div class="stat-number text-primary"><%= summary.total_requests %></div>
                <div class="stat-label">Total Requests</div>
              </div>
              <i class="bi bi-inbox stat-icon"></i>
            </div>
          </div>
        </div>
      </div>

      <!-- Distribution panels -->
      <div class="row g-3 mb-4">
        <div class="col-lg-4">
          <div class="form-section h-100">
            <h6 class="fw-bold mb-3"><i class="bi bi-pie-chart me-2 text-crimson"></i>Users by Role</h6>
            <% if (userRoles.length === 0) { %>
              <p class="small text-muted mb-0">No user data.</p>
            <% } else { %>
              <ul class="list-unstyled small mb-0">
                <% userRoles.forEach(function(row) { %>
                  <li class="d-flex justify-content-between py-1 border-bottom">
                    <span class="text-capitalize"><%= row.role %></span>
                    <span class="fw-semibold"><%= row.count %></span>
                  </li>
                <% }); %>
              </ul>
            <% } %>
          </div>
        </div>
        <div class="col-lg-4">
          <div class="form-section h-100">
            <h6 class="fw-bold mb-3"><i class="bi bi-bar-chart me-2 text-crimson"></i>Listings by Status</h6>
            <% if (listingStatus.length === 0) { %>
              <p class="small text-muted mb-0">No listing data.</p>
            <% } else { %>
              <ul class="list-unstyled small mb-0">
                <% listingStatus.forEach(function(row) { %>
                  <li class="d-flex justify-content-between py-1 border-bottom">
                    <span class="text-capitalize"><%= row.status %></span>
                    <span class="fw-semibold"><%= row.count %></span>
                  </li>
                <% }); %>
              </ul>
            <% } %>
          </div>
        </div>
        <div class="col-lg-4">
          <div class="form-section h-100">
            <h6 class="fw-bold mb-3"><i class="bi bi-tags me-2 text-crimson"></i>Listings by Category</h6>
            <% if (listingCategory.length === 0) { %>
              <p class="small text-muted mb-0">No category data.</p>
            <% } else { %>
              <ul class="list-unstyled small mb-0">
                <% listingCategory.forEach(function(row) { %>
                  <li class="d-flex justify-content-between py-1 border-bottom">
                    <span><%= row.category.replace('_', ' ') %></span>
                    <span class="fw-semibold"><%= row.count %></span>
                  </li>
                <% }); %>
              </ul>
            <% } %>
          </div>
        </div>
      </div>

      <!-- Request status + transaction volume -->
      <div class="row g-3 mb-4">
        <div class="col-lg-8">
          <div class="form-section h-100">
            <h6 class="fw-bold mb-3"><i class="bi bi-inbox me-2 text-crimson"></i>Requests by Status</h6>
            <% if (requestStatus.length === 0) { %>
              <p class="small text-muted mb-0">No request data yet.</p>
            <% } else { %>
              <div class="row g-2">
                <% requestStatus.forEach(function(row) { %>
                  <div class="col-6 col-md-4">
                    <div class="border rounded p-2 text-center">
                      <div class="fs-4 fw-bold"><%= row.count %></div>
                      <div class="small text-muted text-capitalize"><%= row.status %></div>
                    </div>
                  </div>
                <% }); %>
              </div>
            <% } %>
          </div>
        </div>
        <div class="col-lg-4">
          <div class="form-section h-100 text-center">
            <h6 class="fw-bold mb-3"><i class="bi bi-cash-stack me-2 text-crimson"></i>Transaction Volume</h6>
            <div class="fs-3 fw-bold text-crimson">$<%= transactionVolume.toFixed(2) %></div>
            <div class="small text-muted">Total value of accepted requests</div>
          </div>
        </div>
      </div>

      <!-- Recent moderation activity -->
      <div class="form-section mb-4">
        <h6 class="fw-bold mb-3"><i class="bi bi-clock-history me-2 text-crimson"></i>Recent Moderation Activity</h6>
        <% if (recentActions.length === 0) { %>
          <p class="small text-muted mb-0">No moderation actions yet.</p>
        <% } else { %>
          <table class="table table-sm align-middle mb-0">
            <thead>
              <tr>
                <th>Action</th>
                <th>Actor</th>
                <th>Target</th>
                <th>Reason</th>
                <th>When</th>
              </tr>
            </thead>
            <tbody>
              <% recentActions.forEach(function(a) { %>
                <tr>
                  <td><span class="badge bg-secondary text-capitalize"><%= a.action.replace(/_/g, ' ') %></span></td>
                  <td class="small"><%= a.actor_fname ? a.actor_fname + ' ' + a.actor_lname : '—' %></td>
                  <td class="small">
                    <% if (a.listing_title) { %>
                      Listing: <em><%= a.listing_title %></em>
                    <% } else if (a.target_fname) { %>
                      User: <%= a.target_fname %> <%= a.target_lname %>
                    <% } else { %>
                      —
                    <% } %>
                  </td>
                  <td class="small text-muted"><%= a.reason || '—' %></td>
                  <td class="small text-muted"><%= new Date(a.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        <% } %>
      </div>

    </div><!-- /main content -->
  </div><!-- /row -->
</div><!-- /container-fluid -->

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head><%- include('partials/head') %></head>
<body>
<%- include('partials/navbar') %>

<div class="page-header">
  <div class="container">
    <div class="d-flex justify-content-between align-items-start">
      <div>
        <h1 class="h3 fw-bold mb-0"><i class="bi bi-hourglass-split me-2"></i>Pending Listings</h1>
        <p class="text-muted small mb-0">Review and approve or reject listings submitted by students.</p>
      </div>
      <span class="badge bg-warning text-dark px-3 py-2"><%= pendingListings.length %> pending</span>
    </div>
  </div>
</div>

<div class="container py-4">
  <%- include('partials/alerts') %>
  <div class="row g-4">

    <div class="col-lg-3">
      <%- include('partials/sidebar-staff') %>
    </div>

    <div class="col-lg-9">
      <% if (pendingListings.length === 0) { %>
        <div class="text-center py-5 border rounded">
          <i class="bi bi-check-circle fs-1 text-success"></i>
          <p class="text-muted mt-2 mb-0">All caught up! No pending listings to review.</p>
        </div>
      <% } else { %>
        <div class="table-section">
          <table class="table table-hover align-middle mb-0">
            <thead>
              <tr>
                <th>Item</th>
                <th>Owner</th>
                <th>Type</th>
                <th>Price</th>
                <th>Category</th>
                <th>Condition</th>
                <th>Submitted</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% pendingListings.forEach(function(listing) { %>
                <tr>
                  <td>
                    <a href="/listings/<%= listing.id %>" class="text-decoration-none">
                      <span class="fw-semibold small"><%= listing.title %></span>
                    </a>
                  </td>
                  <td class="small text-muted">User #<%= listing.owner_id %></td>
                  <td><span class="status-badge type-<%= listing.type %>"><%= listing.type.toUpperCase() %></span></td>
                  <td class="fw-bold small">
                    <% if (listing.type === 'sell' && listing.price) { %>
                      $<%= listing.price.toFixed(2) %>
                    <% } else if (listing.type === 'free') { %>
                      <span class="text-success">Free</span>
                    <% } else { %>
                      <span class="text-primary">Trade</span>
                    <% } %>
                  </td>
                  <td class="small text-muted"><%= listing.category.replace('_', ' ') %></td>
                  <td class="small text-muted"><%= listing.condition.replace('_', ' ') %></td>
                  <td class="small text-muted"><%= new Date(listing.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %></td>
                  <td>
                    <div class="d-flex gap-1">
                      <form action="/moderator/listings/<%= listing.id %>/approve" method="POST" class="d-inline">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                        <button type="submit" class="btn btn-success btn-sm">
                          <i class="bi bi-check-lg me-1"></i>Approve
                        </button>
                      </form>
                      <button type="button" class="btn btn-outline-danger btn-sm" data-bs-toggle="modal" data-bs-target="#rejectModal<%= listing.id %>">
                        <i class="bi bi-x-lg me-1"></i>Reject
                      </button>
                    </div>
                  </td>
                </tr>

                <div class="modal fade" id="rejectModal<%= listing.id %>" tabindex="-1" aria-hidden="true">
                  <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content">
                      <form action="/moderator/listings/<%= listing.id %>/reject" method="POST">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                        <div class="modal-header">
                          <h5 class="modal-title fw-bold">Reject Listing</h5>
                          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                          <p class="small text-muted">Rejecting: <strong><%= listing.title %></strong></p>
                          <label class="form-label">Reason (optional)</label>
                          <textarea class="form-control" name="reason" rows="3" placeholder="Explain why this listing is being rejected…"></textarea>
                        </div>
                        <div class="modal-footer">
                          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                          <button type="submit" class="btn btn-danger">
                            <i class="bi bi-x-lg me-1"></i>Reject Listing
                          </button>
                        </div>
                      </form>
                    </div>
                  </div>
                </div>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>

  </div>
</div>

<%- include('partials/footer') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

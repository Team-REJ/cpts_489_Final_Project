<!DOCTYPE html>
<html lang="en">
<head><%- include('partials/head') %></head>
<body>
<%- include('partials/navbar') %>

<!-- Breadcrumb -->
<div class="page-header">
  <div class="container">
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb mb-0">
        <li class="breadcrumb-item"><a href="/">Home</a></li>
        <li class="breadcrumb-item"><a href="/listings">Browse Listings</a></li>
        <li class="breadcrumb-item active"><%= listing.title %></li>
      </ol>
    </nav>
  </div>
</div>

<!-- Main content -->
<div class="container py-4">
  <%- include('partials/alerts') %>
  <div class="row g-4">

    <!-- Left column: image + description -->
    <div class="col-lg-7">

      <!-- Main image placeholder -->
      <div class="img-placeholder-lg mb-3">
        <% if (listing.category === 'textbooks') { %>
          <i class="bi bi-book" style="font-size:4rem;color:#aaa;"></i>
        <% } else if (listing.category === 'electronics') { %>
          <i class="bi bi-laptop" style="font-size:4rem;color:#aaa;"></i>
        <% } else if (listing.category === 'furniture') { %>
          <i class="bi bi-person-workspace" style="font-size:4rem;color:#aaa;"></i>
        <% } else if (listing.category === 'sports') { %>
          <i class="bi bi-bicycle" style="font-size:4rem;color:#aaa;"></i>
        <% } else if (listing.category === 'clothing') { %>
          <i class="bi bi-bag" style="font-size:4rem;color:#aaa;"></i>
        <% } else { %>
          <i class="bi bi-box" style="font-size:4rem;color:#aaa;"></i>
        <% } %>
        <span class="small text-muted mt-2" style="font-size:0.9rem;">Item Photo</span>
      </div>

      <!-- Description -->
      <div class="form-section">
        <h5 class="fw-bold mb-3">Description</h5>
        <p class="text-muted mb-0" style="white-space:pre-line;"><%= listing.description %></p>

        <hr />
        <h6 class="fw-bold mb-3">Item Details</h6>
        <div class="row g-2 small">
          <div class="col-6">
            <div class="p-2 bg-light rounded">
              <span class="text-muted d-block">Category</span>
              <strong><%= listing.category.replace('_', ' ') %></strong>
            </div>
          </div>
          <div class="col-6">
            <div class="p-2 bg-light rounded">
              <span class="text-muted d-block">Condition</span>
              <strong><%= listing.condition.replace('_', ' ') %></strong>
            </div>
          </div>
          <div class="col-6">
            <div class="p-2 bg-light rounded">
              <span class="text-muted d-block">Listing Type</span>
              <strong><%= listing.type.charAt(0).toUpperCase() + listing.type.slice(1) %></strong>
            </div>
          </div>
          <div class="col-6">
            <div class="p-2 bg-light rounded">
              <span class="text-muted d-block">Views</span>
              <strong><%= listing.view_count %></strong>
            </div>
          </div>
        </div>
      </div>

    </div>

    <!-- Right column: listing info + actions -->
    <div class="col-lg-5">

      <!-- Price & status -->
      <div class="form-section mb-3">
        <div class="d-flex justify-content-between align-items-start mb-2">
          <div>
            <span class="status-badge badge-<%= listing.status %> me-2"><%= listing.status %></span>
            <span class="status-badge type-<%= listing.type %>"><%= listing.type.toUpperCase() %></span>
          </div>
          <span class="text-muted small"><i class="bi bi-clock me-1"></i>Posted <%= new Date(listing.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
        </div>

        <h2 class="fw-bold mt-2 mb-1"><%= listing.title %></h2>

        <div class="d-flex gap-2 mb-3 flex-wrap">
          <span class="badge bg-light border text-muted">
            <i class="bi bi-tag me-1"></i><%= listing.category.replace('_', ' ') %>
          </span>
          <span class="badge bg-light border text-muted">
            <i class="bi bi-star-half me-1"></i><%= listing.condition.replace('_', ' ') %>
          </span>
        </div>

        <% if (listing.type === 'sell') { %>
          <div class="display-6 fw-bold text-crimson mb-3">$<%= listing.price ? listing.price.toFixed(2) : '0.00' %></div>
        <% } else if (listing.type === 'free') { %>
          <div class="display-6 fw-bold mb-3" style="color:#16a34a;">Free</div>
        <% } else { %>
          <div class="display-6 fw-bold text-primary mb-3">Trade</div>
        <% } %>

        <% if (currentUser && currentUser.id === listing.owner_id) { %>
          <!-- Owner controls -->
          <div class="d-grid gap-2 mb-3">
            <a href="/listings/<%= listing.id %>/edit" class="btn btn-outline-crimson">
              <i class="bi bi-pencil me-1"></i>Edit Listing
            </a>
            <% if (listing.status === 'active') { %>
              <form action="/listings/<%= listing.id %>/sold" method="POST">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <button type="submit" class="btn btn-success w-100" onclick="return confirm('Mark this listing as sold? Any open requests on it will be closed.')">
                  <i class="bi bi-check2-square me-1"></i>Mark as Sold
                </button>
              </form>
            <% } %>
            <form action="/listings/<%= listing.id %>/delete" method="POST">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <button type="submit" class="btn btn-outline-danger w-100" onclick="return confirm('Are you sure you want to delete this listing?')">
                <i class="bi bi-trash me-1"></i>Delete Listing
              </button>
            </form>
          </div>
        <% } else if (currentUser && listing.status === 'active') { %>
          <!-- Purchase request form -->
          <div class="d-grid gap-2 mb-3">
            <button class="btn btn-crimson btn-lg" data-bs-toggle="modal" data-bs-target="#requestModal">
              <i class="bi bi-send-fill me-2"></i>Send Purchase Request
            </button>
          </div>
        <% } else if (!currentUser) { %>
          <div class="d-grid gap-2 mb-3">
            <a href="/login?redirect=<%= encodeURIComponent('/listings/' + listing.id) %>" class="btn btn-crimson btn-lg">
              <i class="bi bi-box-arrow-in-right me-2"></i>Log in to send a request
            </a>
          </div>
        <% } %>
      </div>

      <!-- Safety tips -->
      <div class="alert alert-warning small py-2 px-3 mb-0" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-1"></i>
        <strong>Safety Tip:</strong> Always meet in a public place on campus. Never send payment before seeing the item in person.
      </div>

    </div>

  </div><!-- /row -->
</div><!-- /container -->

<% if (currentUser && currentUser.id !== listing.owner_id && listing.status === 'active') { %>
<!-- Request modal -->
<div class="modal fade" id="requestModal" tabindex="-1" aria-labelledby="requestModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <form action="/requests" method="POST">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <input type="hidden" name="listing_id" value="<%= listing.id %>" />
        <div class="modal-header border-0 pb-0">
          <h5 class="modal-title fw-bold" id="requestModalLabel">Send Purchase Request</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <!-- Listing preview -->
          <div class="d-flex align-items-center bg-light rounded p-2 mb-3">
            <i class="bi bi-tag" style="font-size:2rem;margin-right:10px;color:#aaa;"></i>
            <div>
              <div class="fw-semibold small"><%= listing.title %></div>
              <div class="text-crimson fw-bold">
                <% if (listing.type === 'sell') { %>$<%= listing.price ? listing.price.toFixed(2) : '0.00' %><% } else { %><%= listing.type %><% } %>
              </div>
            </div>
          </div>

          <div class="mb-3">
            <label class="form-label">Your Message <span class="required-star">*</span></label>
            <textarea class="form-control" name="initial_message" rows="3" placeholder="Hi! I'm interested in your item. Is it still available?" required minlength="5"></textarea>
            <div class="form-text">Minimum 5 characters. Introduce yourself to the seller.</div>
          </div>
          <div class="mb-3">
            <label class="form-label">Offer Price <span class="text-muted small">(optional)</span></label>
            <div class="input-group">
              <span class="input-group-text">$</span>
              <input type="number" class="form-control" name="offer_amount" placeholder="Leave blank to accept asking price" min="0" step="0.01" />
            </div>
          </div>
          <div class="alert alert-light small py-2 border mb-0">
            <i class="bi bi-info-circle me-1 text-crimson"></i>
            Your request will be sent to the seller. The seller will be notified and can respond in the chat.
          </div>
        </div>
        <div class="modal-footer border-0 pt-0">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-crimson">
            <i class="bi bi-send-fill me-1"></i>Send Request
          </button>
        </div>
      </form>
    </div>
  </div>
</div>
<% } %>

<%- include('partials/footer') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

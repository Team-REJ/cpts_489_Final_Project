<!DOCTYPE html>
<html lang="en">
<head><%- include('partials/head') %></head>
<body>
<%- include('partials/navbar') %>

<!-- Page header -->
<div class="page-header">
  <div class="container">
    <div class="d-flex justify-content-between align-items-start">
      <div>
        <h1 class="h3 fw-bold mb-0"><i class="bi bi-shield-check me-2"></i>Moderator Dashboard</h1>
        <p class="text-muted small mb-0">Review pending listings, manage flagged content, and monitor marketplace activity.</p>
      </div>
      <span class="badge bg-primary px-3 py-2"><i class="bi bi-shield-fill me-1"></i>Staff</span>
    </div>
  </div>
</div>

<div class="container py-4">
  <%- include('partials/alerts') %>
  <div class="row g-4">

    <!-- Sidebar -->
    <div class="col-lg-3">
      <%- include('partials/sidebar-staff') %>
    </div>

    <!-- Main content -->
    <div class="col-lg-9">

      <!-- Stats -->
      <div class="row g-3 mb-4">
        <div class="col-6 col-md-4">
          <div class="stat-card">
            <div class="d-flex justify-content-between align-items-start">
              <div>
                <div class="stat-number text-warning"><%= pendingListings.length %></div>
                <div class="stat-label">Pending Review</div>
              </div>
              <i class="bi bi-hourglass-split stat-icon"></i>
            </div>
          </div>
        </div>
        <div class="col-6 col-md-4">
          <div class="stat-card">
            <div class="d-flex justify-content-between align-items-start">
              <div>
                <div class="stat-number" style="color:#16a34a;"><%= moderationHistory.length %></div>
                <div class="stat-label">My Actions</div>
              </div>
              <i class="bi bi-check-circle stat-icon"></i>
            </div>
          </div>
        </div>
      </div>

      <!-- Pending Listings -->
      <div class="mb-5">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <h5 class="fw-bold mb-0">
            <i class="bi bi-hourglass-split text-warning me-2"></i>Pending Listings
            <span class="badge bg-warning text-dark ms-2"><%= pendingListings.length %></span>
          </h5>
        </div>

        <% if (pendingListings.length === 0) { %>
          <div class="text-center py-5 border rounded">
            <i class="bi bi-check-circle fs-1 text-success"></i>
            <p class="text-muted mt-2 mb-0">All caught up! No pending listings to review.</p>
          </div>
        <% } else { %>
          <div class="table-section">
            <table class="table table-hover align-middle mb-0">
              <thead>
                <tr>
                  <th>Item</th>
                  <th>Type</th>
                  <th>Price</th>
                  <th>Category</th>
                  <th>Submitted</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% pendingListings.forEach(function(listing) { %>
                  <tr>
                    <td>
                      <a href="/listings/<%= listing.id %>" class="text-decoration-none">
                        <span class="fw-semibold small"><%= listing.title %></span>
                      </a>
                    </td>
                    <td><span class="status-badge type-<%= listing.type %>"><%= listing.type.toUpperCase() %></span></td>
                    <td class="fw-bold small">
                      <% if (listing.type === 'sell' && listing.price) { %>
                        $<%= listing.price.toFixed(2) %>
                      <% } else if (listing.type === 'free') { %>
                        <span class="text-success">Free</span>
                      <% } else { %>
                        <span class="text-primary">Trade</span>
                      <% } %>
                    </td>
                    <td class="small text-muted"><%= listing.category.replace('_', ' ') %></td>
                    <td class="small text-muted"><%= new Date(listing.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %></td>
                    <td>
                      <div class="d-flex gap-1">
                        <form action="/moderator/listings/<%= listing.id %>/approve" method="POST" class="d-inline">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                          <button type="submit" class="btn btn-success btn-sm">
                            <i class="bi bi-check-lg me-1"></i>Approve
                          </button>
                        </form>
                        <button type="button" class="btn btn-outline-danger btn-sm" data-bs-toggle="modal" data-bs-target="#rejectModal<%= listing.id %>">
                          <i class="bi bi-x-lg me-1"></i>Reject
                        </button>
                      </div>
                    </td>
                  </tr>

                  <!-- Reject modal for this listing -->
                  <div class="modal fade" id="rejectModal<%= listing.id %>" tabindex="-1" aria-hidden="true">
                    <div class="modal-dialog modal-dialog-centered">
                      <div class="modal-content">
                        <form action="/moderator/listings/<%= listing.id %>/reject" method="POST">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                          <div class="modal-header">
                            <h5 class="modal-title fw-bold">Reject Listing</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                          </div>
                          <div class="modal-body">
                            <p class="small text-muted">Rejecting: <strong><%= listing.title %></strong></p>
                            <label class="form-label">Reason (optional)</label>
                            <textarea class="form-control" name="reason" rows="3" placeholder="Explain why this listing is being rejected…"></textarea>
                          </div>
                          <div class="modal-footer">
                            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-danger">
                              <i class="bi bi-x-lg me-1"></i>Reject Listing
                            </button>
                          </div>
                        </form>
                      </div>
                    </div>
                  </div>

                <% }); %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>

      <!-- Flag User -->
      <div class="mb-5">
        <h5 class="fw-bold mb-3"><i class="bi bi-flag-fill text-danger me-2"></i>Flag a User</h5>
        <div class="form-section">
          <form action="/moderator/users/0/flag" method="POST" id="flagUserForm">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <div class="row g-3 align-items-end">
              <div class="col-md-3">
                <label class="form-label small fw-semibold">User ID</label>
                <input type="number" class="form-control form-control-sm" id="flagUserId" min="1" placeholder="Enter user ID" required />
              </div>
              <div class="col-md-6">
                <label class="form-label small fw-semibold">Reason</label>
                <input type="text" class="form-control form-control-sm" name="reason" placeholder="Suspicious activity, spam, etc." />
              </div>
              <div class="col-md-3">
                <button type="submit" class="btn btn-outline-danger btn-sm w-100">
                  <i class="bi bi-flag me-1"></i>Flag User
                </button>
              </div>
            </div>
          </form>
        </div>
      </div>

      <!-- Update flag form action dynamically -->
      <script>
        (function() {
          var form = document.getElementById('flagUserForm');
          var input = document.getElementById('flagUserId');
          if (form && input) {
            form.addEventListener('submit', function(e) {
              var userId = input.value;
              if (userId) {
                form.action = '/moderator/users/' + userId + '/flag';
              } else {
                e.preventDefault();
              }
            });
          }
        })();
      </script>

      <!-- Moderation History -->
      <div class="mb-4">
        <h5 class="fw-bold mb-3"><i class="bi bi-clock-history text-crimson me-2"></i>My Moderation History</h5>
        <% if (moderationHistory.length === 0) { %>
          <div class="text-center py-4 border rounded">
            <i class="bi bi-clock fs-2 text-muted"></i>
            <p class="text-muted mt-2 mb-0">No moderation actions taken yet.</p>
          </div>
        <% } else { %>
          <div class="table-section">
            <table class="table table-hover align-middle mb-0">
              <thead>
                <tr>
                  <th>Action</th>
                  <th>Target</th>
                  <th>Reason</th>
                  <th>Date</th>
                </tr>
              </thead>
              <tbody>
                <% moderationHistory.forEach(function(action) { %>
                  <tr>
                    <td>
                      <span class="badge <%= action.action.includes('approve') ? 'bg-success' : action.action.includes('reject') ? 'bg-danger' : 'bg-warning text-dark' %>">
                        <%= action.action.replace('_', ' ') %>
                      </span>
                    </td>
                    <td class="small">
                      <% if (action.target_listing_id) { %>
                        Listing #<%= action.target_listing_id %>
                      <% } %>
                      <% if (action.target_user_id) { %>
                        User #<%= action.target_user_id %>
                      <% } %>
                    </td>
                    <td class="small text-muted"><%= action.reason || '—' %></td>
                    <td class="small text-muted"><%= new Date(action.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>

    </div><!-- /col-lg-9 -->
  </div><!-- /row -->
</div><!-- /container -->

<%- include('partials/footer') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

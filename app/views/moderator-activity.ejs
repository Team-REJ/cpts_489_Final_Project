<!DOCTYPE html>
<html lang="en">
<head><%- include('partials/head') %></head>
<body>
<%- include('partials/navbar') %>

<div class="page-header">
  <div class="container">
    <div class="d-flex justify-content-between align-items-start">
      <div>
        <h1 class="h3 fw-bold mb-0"><i class="bi bi-activity me-2"></i>Platform Activity Feed</h1>
        <p class="text-muted small mb-0">Recent listings, requests, and moderation actions across all users.</p>
      </div>
    </div>
  </div>
</div>

<div class="container py-4">
  <%- include('partials/alerts') %>
  <div class="row g-4">

    <div class="col-lg-3">
      <%- include('partials/sidebar-staff') %>
    </div>

    <div class="col-lg-9">

      <!-- Recent listings -->
      <div class="table-section mb-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <h5 class="fw-bold mb-0"><i class="bi bi-tag-fill text-crimson me-2"></i>Recent Listings</h5>
          <a href="/moderator/listings" class="small text-decoration-none">Pending queue →</a>
        </div>
        <% if (recentListings.length === 0) { %>
          <p class="text-muted small mb-0">No listings yet.</p>
        <% } else { %>
          <table class="table table-sm align-middle mb-0">
            <thead>
              <tr>
                <th>Item</th>
                <th>Owner</th>
                <th>Type</th>
                <th>Status</th>
                <th>Created</th>
              </tr>
            </thead>
            <tbody>
              <% recentListings.forEach(function(l) { %>
                <tr>
                  <td>
                    <a href="/listings/<%= l.id %>" class="text-decoration-none fw-semibold small"><%= l.title %></a>
                  </td>
                  <td class="small text-muted">
                    <%= l.owner_first_name || 'User' %> <%= l.owner_last_name || ('#' + l.owner_id) %>
                  </td>
                  <td><span class="status-badge type-<%= l.type %>"><%= l.type.toUpperCase() %></span></td>
                  <td><span class="status-badge badge-<%= l.status %>"><%= l.status %></span></td>
                  <td class="small text-muted">
                    <%= new Date(l.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit' }) %>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        <% } %>
      </div>

      <!-- Recent requests -->
      <div class="table-section mb-4">
        <h5 class="fw-bold mb-3"><i class="bi bi-inbox-fill text-crimson me-2"></i>Recent Purchase Requests</h5>
        <% if (recentRequests.length === 0) { %>
          <p class="text-muted small mb-0">No requests yet.</p>
        <% } else { %>
          <table class="table table-sm align-middle mb-0">
            <thead>
              <tr>
                <th>Listing</th>
                <th>Buyer</th>
                <th>Status</th>
                <th>Current Offer</th>
                <th>Opened</th>
              </tr>
            </thead>
            <tbody>
              <% recentRequests.forEach(function(r) { %>
                <tr>
                  <td>
                    <a href="/requests/<%= r.id %>" class="text-decoration-none fw-semibold small">
                      <%= r.listing_title || ('Listing #' + r.listing_id) %>
                    </a>
                  </td>
                  <td class="small text-muted">
                    <%= r.buyer_first_name || 'User' %> <%= r.buyer_last_name || ('#' + r.buyer_id) %>
                  </td>
                  <td><span class="status-badge badge-<%= r.status %>"><%= r.status %></span></td>
                  <td class="small">
                    <% if (r.current_offer) { %>
                      $<%= r.current_offer.toFixed(2) %>
                      <span class="text-muted">(<%= r.offered_by %>)</span>
                    <% } else { %>
                      <span class="text-muted">—</span>
                    <% } %>
                  </td>
                  <td class="small text-muted">
                    <%= new Date(r.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit' }) %>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        <% } %>
      </div>

      <!-- Recent moderation actions -->
      <div class="table-section">
        <h5 class="fw-bold mb-3"><i class="bi bi-shield-lock-fill text-crimson me-2"></i>Recent Moderation Actions</h5>
        <% if (recentActions.length === 0) { %>
          <p class="text-muted small mb-0">No moderation actions logged yet.</p>
        <% } else { %>
          <table class="table table-sm align-middle mb-0">
            <thead>
              <tr>
                <th>Action</th>
                <th>Actor</th>
                <th>Target</th>
                <th>Reason</th>
                <th>When</th>
              </tr>
            </thead>
            <tbody>
              <% recentActions.forEach(function(a) { %>
                <tr>
                  <td>
                    <span class="badge <%= a.action.includes('approve') ? 'bg-success' : a.action.includes('reject') || a.action.includes('remove') ? 'bg-danger' : 'bg-warning text-dark' %>">
                      <%= a.action.replace(/_/g, ' ') %>
                    </span>
                  </td>
                  <td class="small text-muted">
                    <%= a.actor_fname ? (a.actor_fname + ' ' + a.actor_lname) : ('User #' + a.actor_id) %>
                  </td>
                  <td class="small text-muted">
                    <% if (a.listing_title) { %>
                      <a href="/listings/<%= a.target_listing_id %>" class="text-decoration-none"><%= a.listing_title %></a>
                    <% } else if (a.target_fname) { %>
                      <%= a.target_fname %> <%= a.target_lname %>
                    <% } else if (a.target_user_id) { %>
                      User #<%= a.target_user_id %>
                    <% } else { %>
                      —
                    <% } %>
                  </td>
                  <td class="small text-muted"><%= a.reason || '—' %></td>
                  <td class="small text-muted">
                    <%= new Date(a.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit' }) %>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        <% } %>
      </div>

    </div>
  </div>
</div>

<%- include('partials/footer') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

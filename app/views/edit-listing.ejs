<!DOCTYPE html>
<html lang="en">
<head><%- include('partials/head') %></head>
<body>
<%- include('partials/navbar') %>

<!-- Page Header -->
<div class="page-header">
  <div class="container">
    <nav aria-label="breadcrumb" class="mb-2">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/">Home</a></li>
        <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
        <li class="breadcrumb-item"><a href="/listings/<%= listing.id %>"><%= listing.title %></a></li>
        <li class="breadcrumb-item active">Edit Listing</li>
      </ol>
    </nav>
    <div class="d-flex justify-content-between align-items-start">
      <div>
        <h1 class="h3 fw-bold mb-0">Edit Listing</h1>
        <p class="text-muted small mb-0">Update your listing details below.</p>
      </div>
      <span class="status-badge badge-<%= listing.status %>"><%= listing.status %></span>
    </div>
  </div>
</div>

<div class="container py-4">
  <%- include('partials/alerts') %>
  <div class="row justify-content-center">
    <div class="col-lg-8">

      <!-- Warning -->
      <div class="alert alert-warning small mb-4" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-1"></i>
        <strong>Heads up:</strong> Editing a live listing may set it back to <strong>Pending</strong> status
        and require re-approval by a moderator.
      </div>

      <form action="/listings/<%= listing.id %>" method="POST">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

        <!-- Basic Info -->
        <div class="form-section mb-4">
          <h5 class="fw-bold mb-4">
            <span class="step-circle d-inline-flex align-items-center justify-content-center me-2"
                  style="width:28px;height:28px;font-size:0.85rem;">1</span>
            Basic Information
          </h5>
          <div class="mb-3">
            <label class="form-label" for="title">Listing Title <span class="required-star">*</span></label>
            <input type="text" class="form-control" id="title" name="title" value="<%= listing.title %>" required />
          </div>
          <div class="mb-0">
            <label class="form-label" for="description">Description <span class="required-star">*</span></label>
            <textarea class="form-control" id="description" name="description" rows="5" required><%= listing.description %></textarea>
          </div>
        </div>

        <!-- Category & Condition -->
        <div class="form-section mb-4">
          <h5 class="fw-bold mb-4">
            <span class="step-circle d-inline-flex align-items-center justify-content-center me-2"
                  style="width:28px;height:28px;font-size:0.85rem;">2</span>
            Category &amp; Condition
          </h5>
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label">Category <span class="required-star">*</span></label>
              <select class="form-select" name="category" required>
                <option value="textbooks" <%= listing.category === 'textbooks' ? 'selected' : '' %>>Textbooks</option>
                <option value="electronics" <%= listing.category === 'electronics' ? 'selected' : '' %>>Electronics</option>
                <option value="furniture" <%= listing.category === 'furniture' ? 'selected' : '' %>>Furniture</option>
                <option value="clothing" <%= listing.category === 'clothing' ? 'selected' : '' %>>Clothing</option>
                <option value="sports" <%= listing.category === 'sports' ? 'selected' : '' %>>Sports</option>
                <option value="dorm_essentials" <%= listing.category === 'dorm_essentials' ? 'selected' : '' %>>Dorm Essentials</option>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label">Condition <span class="required-star">*</span></label>
              <select class="form-select" name="condition" required>
                <option value="new" <%= listing.condition === 'new' ? 'selected' : '' %>>New</option>
                <option value="like_new" <%= listing.condition === 'like_new' ? 'selected' : '' %>>Like New</option>
                <option value="good" <%= listing.condition === 'good' ? 'selected' : '' %>>Good</option>
                <option value="fair" <%= listing.condition === 'fair' ? 'selected' : '' %>>Fair</option>
                <option value="poor" <%= listing.condition === 'poor' ? 'selected' : '' %>>Poor</option>
              </select>
            </div>
          </div>
        </div>

        <!-- Type & Price -->
        <div class="form-section mb-4">
          <h5 class="fw-bold mb-4">
            <span class="step-circle d-inline-flex align-items-center justify-content-center me-2"
                  style="width:28px;height:28px;font-size:0.85rem;">3</span>
            Listing Type &amp; Price
          </h5>
          <div class="mb-3">
            <label class="form-label">Type <span class="required-star">*</span></label>
            <div class="row g-3">
              <div class="col-md-4">
                <label class="d-block border rounded p-3 text-center" style="cursor:pointer;">
                  <input type="radio" name="type" value="sell" class="form-check-input me-1" <%= listing.type === 'sell' ? 'checked' : '' %> />
                  <strong>For Sale</strong>
                  <div class="small text-muted mt-1">You set a price</div>
                </label>
              </div>
              <div class="col-md-4">
                <label class="d-block border rounded p-3 text-center" style="cursor:pointer;">
                  <input type="radio" name="type" value="trade" class="form-check-input me-1" <%= listing.type === 'trade' ? 'checked' : '' %> />
                  <strong>Trade</strong>
                  <div class="small text-muted mt-1">Swap for another item</div>
                </label>
              </div>
              <div class="col-md-4">
                <label class="d-block border rounded p-3 text-center" style="cursor:pointer;">
                  <input type="radio" name="type" value="free" class="form-check-input me-1" <%= listing.type === 'free' ? 'checked' : '' %> />
                  <strong>Free</strong>
                  <div class="small text-muted mt-1">Give it away</div>
                </label>
              </div>
            </div>
          </div>
          <div class="mb-0">
            <label class="form-label">Asking Price</label>
            <div class="input-group" style="max-width:280px;">
              <span class="input-group-text">$</span>
              <input type="number" class="form-control" name="price" value="<%= listing.price || '' %>" min="0" step="0.01" />
            </div>
          </div>
        </div>

        <!-- Danger Zone -->
        <div class="border border-danger rounded p-3 mb-4">
          <h6 class="text-danger fw-bold mb-2">
            <i class="bi bi-exclamation-octagon-fill me-1"></i>Danger Zone
          </h6>
          <p class="small text-muted mb-2">These actions are permanent and cannot be undone.</p>
          <form action="/listings/<%= listing.id %>/delete" method="POST" class="d-inline">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Are you sure you want to permanently delete this listing?')">
              <i class="bi bi-trash me-1"></i>Delete Listing
            </button>
          </form>
        </div>

        <!-- Submit -->
        <div class="d-flex gap-3 justify-content-end">
          <a href="/dashboard" class="btn btn-outline-secondary px-4">Cancel</a>
          <a href="/listings/<%= listing.id %>" class="btn btn-outline-crimson px-4">
            <i class="bi bi-eye me-1"></i>Preview
          </a>
          <button type="submit" class="btn btn-crimson px-5">
            <i class="bi bi-check2-circle me-1"></i>Save Changes
          </button>
        </div>

      </form>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

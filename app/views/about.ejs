<!DOCTYPE html>
<html lang="en">
<head><%- include('partials/head') %></head>
<body>
<%- include('partials/navbar') %>

<!-- Hero -->
<div style="background:linear-gradient(135deg,#1a1a1a,var(--crimson-dark));color:#fff;padding:4rem 0;">
  <div class="container text-center">
    <h1 class="fw-bold mb-2">About CougarMarket</h1>
    <p class="lead mb-0 opacity-75">A campus marketplace built by WSU students, for WSU students.</p>
  </div>
</div>

<!-- About content -->
<div class="container py-5">

  <!-- Project Overview -->
  <div class="row g-5 align-items-center mb-5">
    <div class="col-lg-6">
      <h2 class="fw-bold mb-3">What is CougarMarket?</h2>
      <p class="text-muted mb-3">
        CougarMarket is a campus-exclusive online marketplace designed to make it easy for Washington State
        University students to buy, sell, and trade items within the Cougar community. Whether you're looking
        to offload last semester's textbooks or find affordable furniture for your dorm, CougarMarket connects
        you with fellow students.
      </p>
      <p class="text-muted mb-3">
        Unlike generic platforms like Facebook Marketplace or Craigslist, CougarMarket is built specifically
        for WSU students. All users are verified WSU members, making every transaction safer and more
        trustworthy.
      </p>
      <div class="d-flex gap-3 flex-wrap">
        <% if (!currentUser) { %>
          <a href="/register" class="btn btn-crimson">Get Started</a>
        <% } %>
        <a href="/listings" class="btn btn-outline-crimson">Browse Listings</a>
      </div>
    </div>
    <div class="col-lg-6">
      <div class="row g-3">
        <div class="col-6">
          <div class="p-3 border rounded text-center" style="background:var(--crimson-bg);">
            <i class="bi bi-grid fs-2 text-crimson mb-2 d-block"></i>
            <div class="fw-bold">Listing Management</div>
            <div class="small text-muted mt-1">Post items in minutes with categories, conditions, and photos</div>
          </div>
        </div>
        <div class="col-6">
          <div class="p-3 border rounded text-center" style="background:#eff6ff;">
            <i class="bi bi-chat-dots fs-2 text-primary mb-2 d-block"></i>
            <div class="fw-bold">Request System</div>
            <div class="small text-muted mt-1">Negotiate directly with buyers and sellers via in-app chat</div>
          </div>
        </div>
        <div class="col-6">
          <div class="p-3 border rounded text-center" style="background:#f0fdf4;">
            <i class="bi bi-shield-check fs-2 text-success mb-2 d-block"></i>
            <div class="fw-bold">Admin Moderation</div>
            <div class="small text-muted mt-1">All listings reviewed by moderators before going live</div>
          </div>
        </div>
        <div class="col-6">
          <div class="p-3 border rounded text-center" style="background:#fefce8;">
            <i class="bi bi-arrow-left-right fs-2 text-warning mb-2 d-block"></i>
            <div class="fw-bold">Counteroffer Flow</div>
            <div class="small text-muted mt-1">Negotiate prices back and forth before committing</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Tech Stack — corrected to actual stack -->
  <div class="mb-5">
    <h2 class="fw-bold mb-4 text-center">Technology Stack</h2>
    <div class="row g-3 justify-content-center">
      <div class="col-6 col-md-3 col-lg-2">
        <div class="text-center p-3 border rounded">
          <div class="fw-semibold small">Node.js</div>
          <div class="text-muted" style="font-size:0.72rem;">Runtime</div>
        </div>
      </div>
      <div class="col-6 col-md-3 col-lg-2">
        <div class="text-center p-3 border rounded">
          <div class="fw-semibold small">Express</div>
          <div class="text-muted" style="font-size:0.72rem;">Backend Framework</div>
        </div>
      </div>
      <div class="col-6 col-md-3 col-lg-2">
        <div class="text-center p-3 border rounded">
          <div class="fw-semibold small">EJS</div>
          <div class="text-muted" style="font-size:0.72rem;">Templating</div>
        </div>
      </div>
      <div class="col-6 col-md-3 col-lg-2">
        <div class="text-center p-3 border rounded">
          <div class="fw-semibold small">SQLite</div>
          <div class="text-muted" style="font-size:0.72rem;">Database</div>
        </div>
      </div>
      <div class="col-6 col-md-3 col-lg-2">
        <div class="text-center p-3 border rounded">
          <div class="fw-semibold small">Bootstrap 5</div>
          <div class="text-muted" style="font-size:0.72rem;">Styling</div>
        </div>
      </div>
      <div class="col-6 col-md-3 col-lg-2">
        <div class="text-center p-3 border rounded">
          <div class="fw-semibold small">Vanilla JS</div>
          <div class="text-muted" style="font-size:0.72rem;">Client-Side</div>
        </div>
      </div>
    </div>
  </div>

  <!-- User Roles -->
  <div class="mb-5">
    <h2 class="fw-bold mb-4 text-center">User Roles</h2>
    <div class="table-section">
      <table class="table align-middle mb-0">
        <thead>
          <tr>
            <th>Role</th>
            <th>Description</th>
            <th>Permissions</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>
              <span class="badge" style="background:#dcfce7;color:#15803d;font-size:0.85rem;padding:6px 12px;">
                STUDENT
              </span>
            </td>
            <td class="small text-muted">Default role for all registered WSU students</td>
            <td class="small">Browse listings, create listings, send/receive purchase requests, negotiate</td>
          </tr>
          <tr>
            <td>
              <span class="badge" style="background:#dbeafe;color:#1d4ed8;font-size:0.85rem;padding:6px 12px;">
                MODERATOR
              </span>
            </td>
            <td class="small text-muted">Trusted users who help maintain marketplace quality</td>
            <td class="small">All Student permissions + approve or remove listings, flag users</td>
          </tr>
          <tr>
            <td>
              <span class="badge" style="background:var(--crimson-bg);color:var(--crimson);font-size:0.85rem;padding:6px 12px;">
                ADMIN
              </span>
            </td>
            <td class="small text-muted">Platform administrators with full control</td>
            <td class="small">All Moderator permissions + manage users, change roles, suspend accounts</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Team -->
  <div class="text-center py-4" style="background:var(--crimson-bg);border-radius:16px;">
    <h3 class="fw-bold mb-3">Built by Team REJ</h3>
    <p class="text-muted mb-2">CPT_S 489 — Software Engineering Course Project</p>
    <p class="text-muted mb-4">Washington State University · Spring 2026</p>
    <div class="d-flex justify-content-center gap-2 flex-wrap">
      <span class="badge bg-light border text-muted px-3 py-2">Raul Martinez</span>
      <span class="badge bg-light border text-muted px-3 py-2">Edwin Quinonez</span>
      <span class="badge bg-light border text-muted px-3 py-2">Jaydon Larios</span>
    </div>
    <p class="mt-4 small text-muted">Go Cougs!</p>
  </div>

</div><!-- /container -->

<%- include('partials/footer') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

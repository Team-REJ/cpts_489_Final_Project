<!DOCTYPE html>
<html lang="en">
<head><%- include('partials/head') %></head>
<body>
<%- include('partials/navbar') %>

<div class="page-header">
  <div class="container">
    <div class="d-flex justify-content-between align-items-start">
      <div>
        <h1 class="h3 fw-bold mb-0"><i class="bi bi-flag-fill me-2"></i>User Moderation</h1>
        <p class="text-muted small mb-0">Flag users for admin review or clear flags after investigation.</p>
      </div>
      <span class="badge bg-secondary px-3 py-2"><%= users.length %> users</span>
    </div>
  </div>
</div>

<div class="container py-4">
  <%- include('partials/alerts') %>
  <div class="row g-4">

    <div class="col-lg-3">
      <%- include('partials/sidebar-staff') %>
    </div>

    <div class="col-lg-9">
      <div class="table-section">
        <table class="table table-hover align-middle mb-0">
          <thead>
            <tr>
              <th>User</th>
              <th>Email</th>
              <th>Role</th>
              <th>Status</th>
              <th>Joined</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% users.forEach(function(u) { %>
              <tr>
                <td class="small fw-semibold"><%= u.first_name %> <%= u.last_name %> <span class="text-muted">#<%= u.id %></span></td>
                <td class="small text-muted"><%= u.email %></td>
                <td>
                  <span class="badge <%= u.role === 'admin' ? 'bg-danger' : u.role === 'moderator' ? 'bg-primary' : 'bg-secondary' %>">
                    <%= u.role %>
                  </span>
                </td>
                <td>
                  <% if (u.status === userStatus.FLAGGED) { %>
                    <span class="badge bg-warning text-dark">flagged</span>
                  <% } else if (u.status === userStatus.SUSPENDED) { %>
                    <span class="badge bg-danger">suspended</span>
                  <% } else { %>
                    <span class="badge bg-success">active</span>
                  <% } %>
                </td>
                <td class="small text-muted"><%= new Date(u.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></td>
                <td>
                  <% if (currentUser.id === u.id) { %>
                    <span class="small text-muted">(you)</span>
                  <% } else if (u.role === 'admin') { %>
                    <span class="small text-muted">—</span>
                  <% } else if (u.status === userStatus.FLAGGED) { %>
                    <form action="/moderator/users/<%= u.id %>/unflag" method="POST" class="d-inline">
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                      <button type="submit" class="btn btn-outline-success btn-sm">
                        <i class="bi bi-check-lg me-1"></i>Clear Flag
                      </button>
                    </form>
                  <% } else { %>
                    <button type="button" class="btn btn-outline-danger btn-sm" data-bs-toggle="modal" data-bs-target="#flagModal<%= u.id %>">
                      <i class="bi bi-flag me-1"></i>Flag
                    </button>
                  <% } %>
                </td>
              </tr>

              <% if (currentUser.id !== u.id && u.role !== 'admin' && u.status !== userStatus.FLAGGED) { %>
                <div class="modal fade" id="flagModal<%= u.id %>" tabindex="-1" aria-hidden="true">
                  <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content">
                      <form action="/moderator/users/<%= u.id %>/flag" method="POST">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                        <div class="modal-header">
                          <h5 class="modal-title fw-bold">Flag User</h5>
                          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                          <p class="small text-muted">Flagging: <strong><%= u.first_name %> <%= u.last_name %></strong></p>
                          <label class="form-label">Reason</label>
                          <textarea class="form-control" name="reason" rows="3" placeholder="Suspicious activity, spam, etc." required></textarea>
                        </div>
                        <div class="modal-footer">
                          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                          <button type="submit" class="btn btn-danger">
                            <i class="bi bi-flag-fill me-1"></i>Flag User
                          </button>
                        </div>
                      </form>
                    </div>
                  </div>
                </div>
              <% } %>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>

  </div>
</div>

<%- include('partials/footer') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

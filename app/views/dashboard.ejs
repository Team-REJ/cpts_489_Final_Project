<!DOCTYPE html>
<html lang="en">
<head><%- include('partials/head') %></head>
<body>
<%- include('partials/navbar') %>

<!-- Page header -->
<div class="page-header">
  <div class="container">
    <div class="d-flex align-items-center gap-3">
      <div class="user-avatar-lg"><%= currentUser.first_name.charAt(0) %></div>
      <div>
        <h1 class="h3 fw-bold mb-0">Welcome back, <%= currentUser.first_name %></h1>
        <p class="text-muted small mb-0">
          <%= currentUser.email %> &nbsp;·&nbsp;
          <span class="badge bg-light border text-muted text-uppercase"><%= currentUser.role %></span>
        </p>
      </div>
      <div class="ms-auto">
        <a href="/listings/new" class="btn btn-crimson">
          <i class="bi bi-plus-circle-fill me-1"></i>New Listing
        </a>
      </div>
    </div>
  </div>
</div>

<div class="container py-4">
  <%- include('partials/alerts') %>
  <div class="row g-4">

    <!-- Sidebar -->
    <div class="col-lg-3">
      <%- include('partials/sidebar-student') %>
    </div>

    <!-- Main content -->
    <div class="col-lg-9">

      <!-- Stats row -->
      <% var activeCount = myListings.filter(function(l) { return l.status === 'active'; }).length; %>
      <% var pendingCount = myListings.filter(function(l) { return l.status === 'pending'; }).length; %>
      <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
          <div class="stat-card">
            <div class="d-flex justify-content-between align-items-start">
              <div>
                <div class="stat-number text-crimson"><%= activeCount %></div>
                <div class="stat-label">Active Listings</div>
              </div>
              <i class="bi bi-grid stat-icon"></i>
            </div>
          </div>
        </div>
        <div class="col-6 col-md-3">
          <div class="stat-card">
            <div class="d-flex justify-content-between align-items-start">
              <div>
                <div class="stat-number text-warning"><%= pendingCount %></div>
                <div class="stat-label">Pending Approval</div>
              </div>
              <i class="bi bi-hourglass-split stat-icon"></i>
            </div>
          </div>
        </div>
        <div class="col-6 col-md-3">
          <div class="stat-card">
            <div class="d-flex justify-content-between align-items-start">
              <div>
                <div class="stat-number" style="color:#16a34a;"><%= receivedRequests.length %></div>
                <div class="stat-label">Requests Received</div>
              </div>
              <i class="bi bi-inbox stat-icon"></i>
            </div>
          </div>
        </div>
        <div class="col-6 col-md-3">
          <div class="stat-card">
            <div class="d-flex justify-content-between align-items-start">
              <div>
                <div class="stat-number text-primary"><%= sentRequests.length %></div>
                <div class="stat-label">Requests Sent</div>
              </div>
              <i class="bi bi-send stat-icon"></i>
            </div>
          </div>
        </div>
      </div>

      <!-- Tabs -->
      <ul class="nav nav-tabs mb-4" id="dashTabs">
        <li class="nav-item">
          <button class="nav-link active fw-semibold" data-bs-toggle="tab" data-bs-target="#myListings">
            <i class="bi bi-grid me-1"></i>My Listings
            <span class="badge bg-crimson ms-1"><%= myListings.length %></span>
          </button>
        </li>
        <li class="nav-item">
          <button class="nav-link fw-semibold" data-bs-toggle="tab" data-bs-target="#requestsOnMe">
            <i class="bi bi-inbox me-1"></i>Requests Received
            <span class="badge bg-secondary ms-1"><%= receivedRequests.length %></span>
          </button>
        </li>
        <li class="nav-item">
          <button class="nav-link fw-semibold" data-bs-toggle="tab" data-bs-target="#mySentRequests">
            <i class="bi bi-send me-1"></i>Requests Sent
            <span class="badge bg-secondary ms-1"><%= sentRequests.length %></span>
          </button>
        </li>
      </ul>

      <div class="tab-content">

        <!-- My listings tab -->
        <div class="tab-pane fade show active" id="myListings">
          <% if (myListings.length === 0) { %>
            <div class="text-center py-5">
              <i class="bi bi-inbox fs-1 text-muted"></i>
              <p class="text-muted mt-2">You have no listings yet.</p>
              <a href="/listings/new" class="btn btn-crimson">Create your first listing</a>
            </div>
          <% } else { %>
            <div class="row g-3">
              <% myListings.forEach(function(listing) { %>
                <div class="col-md-6 col-lg-4">
                  <div class="form-section h-100">
                    <div class="d-flex align-items-center mb-2">
                      <i class="bi bi-tag" style="font-size:2rem;margin-right:10px;color:#aaa;"></i>
                      <div class="flex-fill">
                        <div class="fw-semibold text-truncate"><%= listing.title %></div>
                        <% if (listing.type === 'sell' && listing.price) { %>
                          <div class="text-crimson fw-bold">$<%= listing.price.toFixed(2) %></div>
                        <% } else if (listing.type === 'free') { %>
                          <div class="fw-bold" style="color:#16a34a;">Free</div>
                        <% } else { %>
                          <div class="text-primary fw-bold">Trade</div>
                        <% } %>
                      </div>
                    </div>
                    <div class="d-flex gap-1 mb-3">
                      <span class="status-badge badge-<%= listing.status %>"><%= listing.status %></span>
                      <span class="status-badge type-<%= listing.type %>"><%= listing.type.toUpperCase() %></span>
                      <span class="badge bg-light border text-muted small"><%= listing.condition.replace('_', ' ') %></span>
                    </div>
                    <div class="small text-muted mb-3">
                      <i class="bi bi-eye me-1"></i><%= listing.view_count %> views
                    </div>
                    <div class="d-flex gap-2">
                      <a href="/listings/<%= listing.id %>" class="btn btn-outline-crimson btn-sm flex-fill">
                        <i class="bi bi-eye me-1"></i>View
                      </a>
                      <a href="/listings/<%= listing.id %>/edit" class="btn btn-outline-secondary btn-sm flex-fill">
                        <i class="bi bi-pencil me-1"></i>Edit
                      </a>
                      <form action="/listings/<%= listing.id %>/delete" method="POST" class="d-inline">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                        <button type="submit" class="btn btn-outline-danger btn-sm" onclick="return confirm('Delete this listing?')">
                          <i class="bi bi-trash"></i>
                        </button>
                      </form>
                    </div>
                  </div>
                </div>
              <% }); %>
            </div>
          <% } %>
        </div>

        <!-- Requests received tab -->
        <div class="tab-pane fade" id="requestsOnMe">
          <% if (receivedRequests.length === 0) { %>
            <div class="text-center py-5">
              <i class="bi bi-inbox fs-1 text-muted"></i>
              <p class="text-muted mt-2">No requests on your listings yet.</p>
            </div>
          <% } else { %>
            <div class="table-section">
              <table class="table table-hover align-middle mb-0">
                <thead>
                  <tr>
                    <th>Listing</th>
                    <th>Offer</th>
                    <th>Status</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% receivedRequests.forEach(function(req) { %>
                    <tr>
                      <td class="fw-semibold small">Request #<%= req.id %> on Listing #<%= req.listing_id %></td>
                      <td><span class="fw-bold text-crimson small"><%= req.current_offer ? '$' + req.current_offer.toFixed(2) : '—' %></span></td>
                      <td><span class="status-badge badge-<%= req.status %>"><%= req.status %></span></td>
                      <td>
                        <a href="/requests/<%= req.id %>" class="btn btn-crimson btn-sm">
                          <i class="bi bi-chat-dots me-1"></i>View
                        </a>
                      </td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          <% } %>
        </div>

        <!-- Sent requests tab -->
        <div class="tab-pane fade" id="mySentRequests">
          <% if (sentRequests.length === 0) { %>
            <div class="text-center py-5">
              <i class="bi bi-send fs-1 text-muted"></i>
              <p class="text-muted mt-2">You haven't sent any requests yet.</p>
              <a href="/listings" class="btn btn-outline-crimson">Browse listings</a>
            </div>
          <% } else { %>
            <div class="table-section">
              <table class="table table-hover align-middle mb-0">
                <thead>
                  <tr>
                    <th>Listing</th>
                    <th>My Offer</th>
                    <th>Status</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% sentRequests.forEach(function(req) { %>
                    <tr>
                      <td class="fw-semibold small">Request #<%= req.id %> on Listing #<%= req.listing_id %></td>
                      <td><span class="fw-bold text-crimson small"><%= req.current_offer ? '$' + req.current_offer.toFixed(2) : '—' %></span></td>
                      <td><span class="status-badge badge-<%= req.status %>"><%= req.status %></span></td>
                      <td>
                        <a href="/requests/<%= req.id %>" class="btn btn-crimson btn-sm me-1">
                          <i class="bi bi-chat-dots"></i>
                        </a>
                      </td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          <% } %>
        </div>

      </div><!-- /tab-content -->

    </div><!-- /col-lg-9 -->
  </div><!-- /row -->
</div><!-- /container -->

<%- include('partials/footer') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

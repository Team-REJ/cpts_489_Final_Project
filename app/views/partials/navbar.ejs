<nav class="navbar navbar-expand-lg navbar-dark bg-crimson shadow-sm">
  <div class="container">
    <a class="navbar-brand fw-bold" href="/">CougarMarket</a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMain">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navMain">
      <ul class="navbar-nav me-auto mb-2 mb-lg-0">
        <li class="nav-item">
          <a class="nav-link <%= navActive('/') ? 'active-page' : '' %>" href="/" <%- navActive('/') ? 'aria-current="page"' : '' %>>Home</a>
        </li>
        <li class="nav-item">
          <a class="nav-link <%= navActive('/listings') ? 'active-page' : '' %>" href="/listings" <%- navActive('/listings') ? 'aria-current="page"' : '' %>>Browse Listings</a>
        </li>
        <% if (currentUser) { %>
          <li class="nav-item">
            <a class="nav-link <%= navActive('/listings/new') ? 'active-page' : '' %>" href="/listings/new" <%- navActive('/listings/new') ? 'aria-current="page"' : '' %>>Create Listing</a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= navActive('/dashboard') ? 'active-page' : '' %>" href="/dashboard" <%- navActive('/dashboard') ? 'aria-current="page"' : '' %>>Dashboard</a>
          </li>
          <% if (currentUser.role === 'moderator' || currentUser.role === 'admin') { %>
            <li class="nav-item">
              <a class="nav-link <%= navActive('/moderator') ? 'active-page' : '' %>" href="/moderator" <%- navActive('/moderator') ? 'aria-current="page"' : '' %>>Moderator</a>
            </li>
          <% } %>
          <% if (currentUser.role === 'admin') { %>
            <li class="nav-item">
              <a class="nav-link <%= navActive('/admin') ? 'active-page' : '' %>" href="/admin" <%- navActive('/admin') ? 'aria-current="page"' : '' %>>Admin</a>
            </li>
          <% } %>
        <% } %>
        <li class="nav-item">
          <a class="nav-link <%= navActive('/about') ? 'active-page' : '' %>" href="/about" <%- navActive('/about') ? 'aria-current="page"' : '' %>>About</a>
        </li>
      </ul>
      <div class="d-flex gap-2 align-items-center">
        <% if (currentUser) { %>
          <a href="/notifications" class="text-white text-decoration-none position-relative me-3" id="navBellLink">
            <i class="bi bi-bell-fill"></i>
            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" id="navBellBadge" style="font-size:0.6rem;display:none;">
              0
            </span>
          </a>
          <span class="text-white small me-2">
            <i class="bi bi-person-circle"></i>
            <%= currentUser.first_name %>
            <span class="badge bg-light text-dark ms-1 text-uppercase"><%= currentUser.role %></span>
          </span>
          <form action="/logout" method="POST" class="m-0">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <button type="submit" class="btn btn-outline-light btn-sm">Log out</button>
          </form>
        <% } else { %>
          <a href="/login" class="btn btn-outline-light btn-sm">Login</a>
          <a href="/register" class="btn btn-light btn-sm fw-semibold" style="color:var(--crimson);">Sign Up</a>
        <% } %>
      </div>
    </div>
  </div>
</nav>

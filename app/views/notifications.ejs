<!DOCTYPE html>
<html lang="en">
<head><%- include('partials/head') %></head>
<body>
<%- include('partials/navbar') %>

<!-- Page header -->
<div class="page-header">
  <div class="container">
    <div class="d-flex justify-content-between align-items-center">
      <div>
        <h1 class="h3 fw-bold mb-0"><i class="bi bi-bell-fill me-2"></i>Notifications</h1>
        <p class="text-muted small mb-0">Stay up to date with your listing activity.</p>
      </div>
      <% if (typeof notifications !== 'undefined' && notifications.length > 0) { %>
        <form action="/api/notifications/read-all" method="POST" id="markAllReadForm">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <button type="button" class="btn btn-outline-crimson btn-sm" id="markAllReadBtn">
            <i class="bi bi-check2-all me-1"></i>Mark all as read
          </button>
        </form>
      <% } %>
    </div>
  </div>
</div>

<div class="container py-4">
  <%- include('partials/alerts') %>
  <div class="row g-4">

    <!-- Sidebar -->
    <div class="col-lg-3">
      <%- include('partials/sidebar-student') %>
    </div>

    <!-- Main content -->
    <div class="col-lg-9">
      <% if (typeof notifications === 'undefined' || notifications.length === 0) { %>
        <div class="text-center py-5">
          <i class="bi bi-bell-slash fs-1 text-muted"></i>
          <p class="text-muted mt-2 mb-0">You have no notifications.</p>
        </div>
      <% } else { %>
        <div class="list-group" id="notificationList">
          <% notifications.forEach(function(notif) { %>
            <div class="list-group-item list-group-item-action d-flex align-items-start gap-3 py-3 notification-item <%= notif.is_read ? '' : 'bg-light' %>"
                 data-id="<%= notif.id %>" data-read="<%= notif.is_read %>">
              <div class="flex-shrink-0">
                <% if (notif.type === 'request_received') { %>
                  <i class="bi bi-inbox-fill text-crimson fs-5"></i>
                <% } else if (notif.type === 'request_accepted') { %>
                  <i class="bi bi-check-circle-fill text-success fs-5"></i>
                <% } else if (notif.type === 'request_rejected') { %>
                  <i class="bi bi-x-circle-fill text-danger fs-5"></i>
                <% } else if (notif.type === 'listing_approved') { %>
                  <i class="bi bi-shield-fill-check text-success fs-5"></i>
                <% } else if (notif.type === 'listing_rejected') { %>
                  <i class="bi bi-shield-fill-x text-danger fs-5"></i>
                <% } else if (notif.type === 'message_received') { %>
                  <i class="bi bi-chat-dots-fill text-primary fs-5"></i>
                <% } else if (notif.type === 'offer_made') { %>
                  <i class="bi bi-currency-dollar text-warning fs-5"></i>
                <% } else { %>
                  <i class="bi bi-bell-fill text-muted fs-5"></i>
                <% } %>
              </div>
              <div class="flex-fill">
                <div class="d-flex justify-content-between">
                  <div class="small <%= notif.is_read ? 'text-muted' : 'fw-semibold' %>"><%= notif.body %></div>
                  <% if (!notif.is_read) { %>
                    <span class="badge bg-crimson rounded-pill" style="height:fit-content;">New</span>
                  <% } %>
                </div>
                <div class="small text-muted mt-1">
                  <i class="bi bi-clock me-1"></i><%= new Date(notif.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit' }) %>
                  <% if (notif.related_request_id) { %>
                    &nbsp;·&nbsp; <a href="/requests/<%= notif.related_request_id %>" class="text-crimson">View request</a>
                  <% } else if (notif.related_listing_id) { %>
                    &nbsp;·&nbsp; <a href="/listings/<%= notif.related_listing_id %>" class="text-crimson">View listing</a>
                  <% } %>
                </div>
              </div>
            </div>
          <% }); %>
        </div>
      <% } %>
    </div>

  </div><!-- /row -->
</div><!-- /container -->

<%- include('partials/footer') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/notifications.js"></script>
</body>
</html>

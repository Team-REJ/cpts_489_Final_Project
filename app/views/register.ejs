<!DOCTYPE html>
<html lang="en">
<head><%- include('partials/head') %></head>
<body>
<%- include('partials/navbar') %>

<main class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
      <h1 class="h3 mb-4">Create your account</h1>
      <%- include('partials/alerts') %>

      <form action="/register" method="POST" class="p-4 bg-white border rounded">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

        <div class="row">
          <div class="col mb-3">
            <label for="first_name" class="form-label">First name</label>
            <input
              id="first_name"
              name="first_name"
              type="text"
              class="form-control"
              value="<%= values && values.first_name || '' %>"
              required
            />
          </div>
          <div class="col mb-3">
            <label for="last_name" class="form-label">Last name</label>
            <input
              id="last_name"
              name="last_name"
              type="text"
              class="form-control"
              value="<%= values && values.last_name || '' %>"
              required
            />
          </div>
        </div>

        <div class="mb-3">
          <label for="email" class="form-label">WSU Email</label>
          <input
            id="email"
            name="email"
            type="email"
            class="form-control"
            value="<%= values && values.email || '' %>"
            placeholder="you@wsu.edu"
            required
          />
          <div class="form-text">Must be a @wsu.edu address.</div>
        </div>

        <div class="mb-3">
          <label for="password" class="form-label">Password</label>
          <input
            id="password"
            name="password"
            type="password"
            class="form-control"
            autocomplete="new-password"
            minlength="8"
            required
          />
          <div class="form-text">At least 8 characters.</div>
        </div>

        <button type="submit" class="btn btn-crimson w-100">Create account</button>

        <p class="small text-muted mt-3 mb-0 text-center">
          Already have an account? <a href="/login">Log in</a>.
        </p>
      </form>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
</body>
</html>

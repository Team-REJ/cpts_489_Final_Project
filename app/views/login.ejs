<!DOCTYPE html>
<html lang="en">
<head><%- include('partials/head') %></head>
<body>
<%- include('partials/navbar') %>

<main class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
      <h1 class="h3 mb-4">Log in</h1>
      <%- include('partials/alerts') %>

      <form action="/login" method="POST" class="p-4 bg-white border rounded">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <input type="hidden" name="redirect" value="<%= typeof redirect !== 'undefined' ? redirect : '' %>" />

        <div class="mb-3">
          <label for="email" class="form-label">WSU Email</label>
          <input
            id="email"
            name="email"
            type="email"
            class="form-control"
            value="<%= values && values.email || '' %>"
            autocomplete="email"
            required
          />
        </div>

        <div class="mb-3">
          <label for="password" class="form-label">Password</label>
          <input
            id="password"
            name="password"
            type="password"
            class="form-control"
            autocomplete="current-password"
            required
          />
        </div>

        <button type="submit" class="btn btn-crimson w-100">Log in</button>

        <p class="small text-muted mt-3 mb-0 text-center">
          New here? <a href="/register">Create an account</a>.
        </p>
      </form>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
</body>
</html>
